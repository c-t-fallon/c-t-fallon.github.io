@page "/tools/beam-analysis"

<PageTitle>Beam Analysis — c-t-fallon</PageTitle>

<div class="beam-tool">
    <header class="beam-tool-header">
        <h2 class="beam-tool-title">beam analysis</h2>
        <p class="beam-tool-subtitle">shear &amp; moment via singularity functions</p>
    </header>

    <div class="beam-tool-body">

        <section class="inputs-panel">
            <h3 class="panel-heading">inputs</h3>

            <div class="input-group">
                <label class="input-label">span</label>
                <div class="input-row">
                    <input class="num-input" type="number" @bind="SpanFt" min="0.1" step="0.5" />
                    <span class="unit">ft</span>
                </div>
            </div>

            <div class="input-group">
                <label class="input-label">start support</label>
                <select class="select-input" @bind="StartSupport">
                    <option value="Pin">pin</option>
                    <option value="Fixed">fixed</option>
                    <option value="Free">free</option>
                </select>
            </div>

            <div class="input-group">
                <label class="input-label">end support</label>
                <select class="select-input" @bind="EndSupport">
                    <option value="Pin">pin</option>
                    <option value="Fixed">fixed</option>
                    <option value="Free">free</option>
                </select>
            </div>

            <div class="input-group">
                <label class="input-label">loads</label>
                <p class="placeholder-note">load input — coming soon</p>
            </div>

            <button class="run-btn" @onclick="RunAnalysis">analyze</button>
        </section>

        <section class="results-panel">
            <h3 class="panel-heading">results</h3>

            @if (!HasResults)
            {
                <p class="results-empty">configure inputs and click analyze.</p>
            }
            else
            {
                <div class="results-placeholder">
                    <p class="placeholder-note">shear &amp; moment diagrams — coming soon</p>
                </div>
            }
        </section>

    </div>
</div>

@code {
    private double SpanFt { get; set; } = 20.0;
    private string StartSupport { get; set; } = "Pin";
    private string EndSupport { get; set; } = "Pin";
    private bool HasResults { get; set; }

    private void RunAnalysis()
    {
        // TODO: build Beam from inputs, apply loads, call ComputeInternalForce()
        HasResults = true;
    }
}
