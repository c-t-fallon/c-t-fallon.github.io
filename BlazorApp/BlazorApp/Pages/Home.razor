@page "/"
@inject BlazorApp.Services.ContentService Content

<PageTitle>c-t-fallon</PageTitle>

<div class="home">
    <header class="home-header">
        <span class="home-handle">c-t-fallon</span>
        <span class="home-tagline">structural engineering &amp; software</span>
    </header>

    <div class="feed">
        @if (!Content.Feed.Any())
        {
            <p class="feed-empty">nothing here yet.</p>
        }
        else
        {
            @foreach (var item in Content.Feed)
            {
                <div class="feed-item">
                    <span class="feed-date">@item.Date.ToString("yyyy-MM-dd")</span>
                    <span class="feed-kind @item.Kind.ToString().ToLower()">@item.Kind.ToString().ToLower()</span>
                    <div class="feed-body">
                        @if (!string.IsNullOrEmpty(item.Href))
                        {
                            <a class="feed-title" href="@item.Href">@item.Title</a>
                        }
                        else
                        {
                            <span class="feed-title">@item.Title</span>
                        }
                        <p class="feed-desc">@item.Description</p>
                    </div>
                </div>
            }
        }
    </div>
</div>
